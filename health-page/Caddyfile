:18790 {
    # Proxy vers le dashboard OpenClaw
    handle /dashboard* {
        reverse_proxy http://localhost:18789 {
            header_up Host localhost
        }
    }

    # Health page statique
    handle /health* {
        root * /home/node/.openclaw/workspace/health-page
        try_files {path} /index.html
        file_server
    }

    # Par défaut : proxy dashboard
    handle {
        reverse_proxy http://localhost:18789 {
            header_up Host localhost
        }
    }

    log {
        output file /home/node/.openclaw/caddy-access.log
    }
}